{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "quoteProps": "as-needed",
  "semi": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "ignorePatterns": ["dist"],
  "sortImports": {
    "internalPattern": ["@/"],
    "newlinesBetween": true,
    "groups": [
      "builtin",
      "external",
      "internal",
      ["parent", "sibling", "index"],
      "style",
      "unknown"
    ]
  }
}
